    <!-- Onboarding / permissions -->
    <string name="onboarding_title">Before we start</string>
    <string name="onboarding_intro">WakeMeThere needs a few permissions to wake you up reliably. We ask for each one with an explanation first.</string>
    <string name="perm_location_title">Location</string>
    <string name="perm_location_desc">We track your position during the trip to know when you get close to your stop. Only while-in-use access is needed — tracking runs in a visible foreground service, never silently.</string>
    <string name="perm_notifications_title">Notifications</string>
    <string name="perm_notifications_desc">The persistent trip notification and the wake-up alarm are delivered as notifications. Without this, the alarm cannot appear.</string>
    <string name="perm_fullscreen_title">Full-screen alarm</string>
    <string name="perm_fullscreen_desc">Allows the alarm to take over the screen like an incoming call, even when the phone is locked and you are asleep.</string>
    <string name="perm_battery_title">Battery optimization</string>
    <string name="perm_battery_desc">Aggressive battery savers (especially on Xiaomi and Samsung phones) can silently kill tracking mid-trip. Exempting WakeMeThere keeps the alarm reliable.</string>
    <string name="perm_grant">Grant</string>
    <string name="perm_granted">Granted</string>
    <string name="perm_open_settings">Open settings</string>
    <string name="perm_denied_title">Some permissions are missing</string>
    <string name="perm_denied_location">Without location access the app cannot track your trip at all.</string>
    <string name="perm_denied_notifications">Without notifications the alarm cannot ring. Enable them in app settings.</string>
    <string name="perm_denied_fullscreen">Without full-screen permission the alarm shows only as a normal notification and may not wake you.</string>
    <string name="perm_skip">Skip for now</string>
    <string name="perm_continue">Continue</string>

