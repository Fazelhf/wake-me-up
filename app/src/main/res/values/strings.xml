    <!-- Onboarding / permissions -->
    <string name="onboarding_title">قبل از شروع</string>
    <string name="onboarding_intro">WakeMeThere برای این‌که مطمئن بیدارت کند به چند مجوز نیاز دارد. هر کدام را قبل از پنجرهٔ سیستمی توضیح می‌دهیم.</string>
    <string name="perm_location_title">موقعیت مکانی</string>
    <string name="perm_location_desc">در طول سفر موقعیتت را دنبال می‌کنیم تا بفهمیم کی به ایستگاهت نزدیک شده‌ای. فقط دسترسی «حین استفاده» لازم است — ردیابی در یک سرویس قابل‌مشاهده انجام می‌شود، نه مخفیانه.</string>
    <string name="perm_notifications_title">اعلان‌ها</string>
    <string name="perm_notifications_desc">اعلان دائمی سفر و خود هشدار بیدارباش به‌صورت اعلان نمایش داده می‌شوند. بدون این مجوز، هشدار نمی‌تواند ظاهر شود.</string>
    <string name="perm_fullscreen_title">هشدار تمام‌صفحه</string>
    <string name="perm_fullscreen_desc">اجازه می‌دهد هشدار مثل تماس ورودی کل صفحه را بگیرد، حتی وقتی گوشی قفل است و خوابیده‌ای.</string>
    <string name="perm_battery_title">بهینه‌سازی باتری</string>
    <string name="perm_battery_desc">بهینه‌سازهای تهاجمی باتری (به‌خصوص در گوشی‌های شیائومی و سامسونگ) می‌توانند ردیابی را وسط سفر بی‌صدا متوقف کنند. معاف کردن WakeMeThere هشدار را قابل‌اعتماد نگه می‌دارد.</string>
    <string name="perm_grant">اعطای مجوز</string>
    <string name="perm_granted">اعطا شد</string>
    <string name="perm_open_settings">باز کردن تنظیمات</string>
    <string name="perm_denied_title">برخی مجوزها داده نشده‌اند</string>
    <string name="perm_denied_location">بدون دسترسی به موقعیت مکانی، برنامه اصلاً نمی‌تواند سفرت را ردیابی کند.</string>
    <string name="perm_denied_notifications">بدون اعلان‌ها هشدار نمی‌تواند زنگ بزند. آن‌ها را در تنظیمات برنامه فعال کن.</string>
    <string name="perm_denied_fullscreen">بدون مجوز تمام‌صفحه، هشدار فقط به‌صورت اعلان عادی نشان داده می‌شود و شاید بیدارت نکند.</string>
